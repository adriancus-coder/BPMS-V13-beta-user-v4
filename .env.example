# Sanctuary Voice — environment configuration template
# Copy to .env and fill values. Single source of truth for all env vars used in code
# (sync'd with render.yaml). Defaults shown in parentheses are server.js fallbacks.

# ─── OpenAI (REQUIRED for translation) ────────────────────────────────────────
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4.1-nano
OPENAI_TRANSCRIBE_MODEL=gpt-4o-mini-transcribe

# ─── Speech provider ──────────────────────────────────────────────────────────
# openai = OpenAI audio transcription chunks (default)
# azure_sdk = Microsoft Cognitive Services Speech SDK continuous streaming
SPEECH_PROVIDER=openai

# ─── Azure Speech (only needed when SPEECH_PROVIDER=azure_sdk) ────────────────
AZURE_SPEECH_KEY=
AZURE_SPEECH_REGION=

# ─── Rate limits ──────────────────────────────────────────────────────────────
TRANSCRIBE_RATE_LIMIT_WINDOW_MS=60000
TRANSCRIBE_RATE_LIMIT_MAX=40

# ─── Admin / operator authentication ──────────────────────────────────────────
# PINs for admin login + special roles
MASTER_ADMIN_PIN=
MASTER_MODERATOR_PIN=
MAIN_OPERATOR_PIN=
# Legacy alias for admin code (also accepted: APP_ADMIN_CODE)
ADMIN_CODE=

# Admin session cookie config
ADMIN_SESSION_SECRET=
ADMIN_SESSION_PERSISTENT=0
ADMIN_SESSION_MAX_AGE_HOURS=12

# Operator session cookie max age (V8 operator dashboard)
OPERATOR_SESSION_MAX_AGE_HOURS=4

# ─── Public URLs ──────────────────────────────────────────────────────────────
PUBLIC_BASE_URL=https://sanctuaryvoice.com
ADMIN_APP_BASE_URL=https://app.sanctuaryvoice.com
ADMIN_APP_HOSTNAMES=app.sanctuaryvoice.com,control.sanctuaryvoice.com,kontrol.sanctuaryvoice.com

# ─── Organization defaults ────────────────────────────────────────────────────
DEFAULT_ORG_ID=sanctuary-voice
DEFAULT_ORG_NAME=Sanctuary Voice
DEFAULT_ORG_PLAN=internal
COMMERCIAL_MODE=0

# ─── Storage paths ────────────────────────────────────────────────────────────
# DATA_DIR defaults to /var/data on Render, ./data locally. Holds sessions.json,
# translation-cache.json, lang-mismatch-log.json, audit-backup-*.json, sessions.backup-*.json
DATA_DIR=

# LOG_DIR defaults to ./logs. Rotating logger writes app.log (5MB rotation, 3 archives)
LOG_DIR=

# ─── Audio archive (optional — archives raw audio chunks per event) ──────────
AUDIO_ARCHIVE_ENABLED=0
AUDIO_ARCHIVE_DIR=
AUDIO_ARCHIVE_MAX_BYTES_PER_EVENT=

# ─── Web Push notifications (optional) ────────────────────────────────────────
# Generate keys with: npx web-push generate-vapid-keys
WEB_PUSH_PUBLIC_KEY=
WEB_PUSH_PRIVATE_KEY=
WEB_PUSH_SUBJECT=mailto:admin@sanctuaryvoice.com

# ─── Monitoring / webhooks (optional) ─────────────────────────────────────────
# When set, post-event summary is sent to this webhook (e.g. Slack/Discord)
SUMMARY_WEBHOOK_URL=
SUMMARY_RECIPIENT=

# Set to 1 to enable in-memory translation monitor (debug only — small overhead)
TRANSLATION_MONITOR_ENABLED=0

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3000
